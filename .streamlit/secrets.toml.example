# このファイルを `.streamlit/secrets.toml` にコピーして値を差し替えてください。
# `.streamlit/secrets.toml` は .gitignore 対象なのでリポジトリには含めません。

# ---- 必須 ----
SUPABASE_URL = "https://xxxxxxxx.supabase.co"
SUPABASE_KEY = "eyJ..."                 # Supabase プロジェクトの anon キー
APP_PASSWORD = "set-a-strong-password"  # アプリのログインパスワード
GROQ_API_KEY = "gsk_..."                # Groq (LLM / クラウド文字起こし用)

# ---- 任意 ----
# 話者分離を有効化する場合のみ（未設定なら話者分離はスキップ）
HUGGINGFACE_TOKEN = ""

# ローカル文字起こしモデルサイズ: tiny / base / small / medium / large-v3
# 既定は small（CPU でも実用速度）。高精度にしたい場合は medium または large-v3
WHISPER_MODEL_SIZE = "small"
